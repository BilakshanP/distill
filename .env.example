# Database
DATABASE_URL=postgres://distill:distill@localhost:5432/distill

# Server
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000

# Migrations (true = auto-run on boot, false = manual via sqlx-cli)
AUTO_MIGRATE=true

# JWT (generate a random string: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-secret

# GitHub OAuth App
# Create at: https://github.com/settings/developers → "New OAuth App"
#   Application name: Distill (dev)
#   Homepage URL: http://localhost:3000
#   Authorization callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=your-client-id-here
GITHUB_CLIENT_SECRET=your-client-secret-here
