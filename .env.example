# Database
DATABASE_URL=postgres://distill:distill@localhost:5432/distill

# Server
HOST=0.0.0.0
PORT=3000
BASE_URL=http://localhost:3000

# Migrations (true = auto-run on boot, false = manual via sqlx-cli)
AUTO_MIGRATE=true

# JWT (generate a random string: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-secret

# GitHub OAuth App
# Create at: https://github.com/settings/developers → "New OAuth App"
#   Application name: Distill (dev)
#   Homepage URL: http://localhost:3000
#   Authorization callback URL: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=your-client-id-here
GITHUB_CLIENT_SECRET=your-client-secret-here

# LLM / Embeddings (optional — if not set, AI features are disabled)
# genai auto-detects provider from model name prefix (gemini-*, gpt-*, claude-*, etc.)
# Set the API key for your chosen provider (genai reads these from env):
#   OPENAI_API_KEY=sk-...
#   GEMINI_API_KEY=...
#   ANTHROPIC_API_KEY=sk-ant-...
#   (or leave empty for local Ollama)
LLM_CHAT_MODEL=gemini-2.0-flash-lite
LLM_EMBEDDING_MODEL=gemini-embedding-001
